{
  "name": "Phoenix Zumble (Rust + MUSL)",
  "build": {
    "dockerfile": "Dockerfile.devcontainer",
    "context": ".."
  },

  "remoteUser": "vscode",

  "containerEnv": {
    "CARGO_NET_GIT_FETCH_WITH_CLI": "true",
    "CC_x86_64_unknown_linux_musl": "musl-gcc",
    "CARGO_TARGET_X86_64_UNKNOWN_LINUX_MUSL_LINKER": "musl-gcc",
    "RUST_LOG": "info"
  },

  "mounts": [
    // caches persistants pour accélérer les builds
    "source=devcontainer-cargo-registry,target=/usr/local/cargo/registry,type=volume",
    "source=devcontainer-cargo-git,target=/usr/local/cargo/git,type=volume",
    "source=devcontainer-target,target=/workspace/target,type=volume"
  ],

  "forwardPorts": [64738, 8080],
  "portsAttributes": {
    "64738": { "label": "Mumble TCP", "onAutoForward": "notify" },
    "8080":  { "label": "Zumble HTTP", "onAutoForward": "notify" }
  },

  "settings": {
    // VS Code settings (si tu utilises VS Code via DevPod)
    "rust-analyzer.cargo.target": "x86_64-unknown-linux-musl",
    "rust-analyzer.checkOnSave.command": "clippy",
    "editor.formatOnSave": true
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "serayuzgur.crates",
        "vadimcn.vscode-lldb",
        "ms-azuretools.vscode-docker"
      ]
    }
  },

  "updateContentCommand": "echo -n",

  "postCreateCommand": [
    // outils rust et cibles
    "rustup show",
    "rustup component add rustfmt clippy",
    "rustup target add x86_64-unknown-linux-musl",
    // utilitaires cargo utiles (optionnels)
    "cargo install --locked cargo-edit cargo-watch || true",
    // marquer le repo comme safe si nécessaire
    "git config --global --add safe.directory /workspace || true"
  ]
}
